{
  "datasets": [
    {
      "name": "63fab333",
      "displayName": "kpi1",
      "queryLines": [
        "-- Monthly revenue \r\n",
        "SELECT \r\n",
        "  year,\r\n",
        "  month,\r\n",
        "  month_name,\r\n",
        "  ROUND(SUM(total_revenue), 2) AS revenue_usd\r\n",
        "FROM electronic_retailer.03_Gold.data_cube_sales\r\n",
        "WHERE year = 2016\r\n",
        "GROUP BY year, month, month_name\r\n",
        "ORDER BY month"
      ],
      "catalog": "electronic_retailer",
      "schema": "03_gold"
    },
    {
      "name": "31b020a2",
      "displayName": "data_cube_sales",
      "queryLines": [
        ""
      ],
      "catalog": "electronic_retailer",
      "schema": "03_gold"
    },
    {
      "name": "7ad90c65",
      "displayName": "kpi2",
      "queryLines": [
        "WITH monthly_revenue AS ( SELECT month, month_name, ROUND(SUM(total_revenue), 2) AS revenue_usd FROM electronic_retailer.03_Gold.data_cube_sales WHERE year = 2016 GROUP BY month, month_name ), total AS ( SELECT SUM(revenue_usd) AS total_revenue FROM monthly_revenue ) \r\n",
        "SELECT month, month_name, revenue_usd, ROUND((revenue_usd / total_revenue) * 100, 2) AS percentage FROM monthly_revenue, total ORDER BY revenue_usd DESC LIMIT 3"
      ]
    },
    {
      "name": "c448dc67",
      "displayName": "kpi3",
      "queryLines": [
        "WITH q2_revenue AS (\r\n",
        "  SELECT \r\n",
        "    category,\r\n",
        "    ROUND(SUM(total_revenue), 2) AS peak_month_revenue\r\n",
        "  FROM electronic_retailer.03_Gold.data_cube_sales\r\n",
        "  WHERE year = 2016 AND month IN (4, 5, 6)\r\n",
        "  GROUP BY category\r\n",
        "),\r\n",
        "total AS (\r\n",
        "  SELECT SUM(peak_month_revenue) AS q2_total FROM q2_revenue\r\n",
        ")\r\n",
        "SELECT \r\n",
        "  category,\r\n",
        "  peak_month_revenue,\r\n",
        "  ROUND((peak_month_revenue / q2_total) * 100, 2) AS pct_of_peak_total\r\n",
        "FROM q2_revenue, total\r\n",
        "ORDER BY peak_month_revenue DESC"
      ]
    },
    {
      "name": "b02aa9a1",
      "displayName": "kpi4",
      "queryLines": [
        "SELECT \r\n",
        "  ROUND(SUM(avg_delivery_days * order_count) / SUM(order_count), 2) AS average_days,\r\n",
        "  SUM(order_count) AS total_orders\r\n",
        "FROM electronic_retailer.03_Gold.data_cube_sales\r\n",
        "WHERE avg_delivery_days IS NOT NULL"
      ]
    },
    {
      "name": "efba2031",
      "displayName": "kpi5",
      "queryLines": [
        "SELECT \r\n",
        "  customer_country AS country,\r\n",
        "  ROUND(SUM(avg_delivery_days * order_count) / SUM(order_count), 2) AS avg_days,\r\n",
        "  SUM(order_count) AS order_count\r\n",
        "FROM electronic_retailer.03_Gold.data_cube_sales\r\n",
        "WHERE avg_delivery_days IS NOT NULL\r\n",
        "GROUP BY customer_country\r\n",
        "ORDER BY avg_days DESC\r\n"
      ],
      "catalog": "electronic_retailer",
      "schema": "03_gold"
    },
    {
      "name": "f4672e58",
      "displayName": "kpi7",
      "queryLines": [
        "WITH category_units AS (\r\n",
        "  SELECT \r\n",
        "    category,\r\n",
        "    SUM(total_quantity) AS units_sold\r\n",
        "  FROM electronic_retailer.03_Gold.data_cube_sales\r\n",
        "  GROUP BY category\r\n",
        "),\r\n",
        "total AS (\r\n",
        "  SELECT SUM(units_sold) AS total_units FROM category_units\r\n",
        ")\r\n",
        "SELECT \r\n",
        "  category,\r\n",
        "  units_sold,\r\n",
        "  ROUND((units_sold / total_units) * 100, 2) AS percentage\r\n",
        "FROM category_units, total\r\n",
        "ORDER BY units_sold DESC\r\n"
      ]
    }
  ],
